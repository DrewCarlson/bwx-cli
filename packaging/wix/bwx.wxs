<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX 4 source for the bwx-cli MSI.

  Per-user install (no UAC elevation) under
  %LOCALAPPDATA%\Programs\bwx. Files: bwx.exe, bwx-agent.exe, the
  three shell completions generated by the release workflow, README,
  LICENSE. Adds the install dir to the user's PATH via the
  Environment element.

  This MSI deliberately does NOT call `bwx setup-os` as a custom
  action — the Scheduled Task / SSH_AUTH_SOCK plumbing is invoked by
  the user post-install with `bwx setup-os`. Keeping setup out of the
  installer keeps it idempotent and uninstall-safe.

  Build:
    wix build packaging/wix/bwx.wxs -arch x64 \
      -d Version=2.4.0.0 -d DisplayVersion=2.4.0 \
      -d ExeDir=target/x86_64-pc-windows-msvc/release \
      -o dist/bwx-cli-2.4.0-x86_64-pc-windows-msvc.msi
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
      Name="bwx-cli"
      Manufacturer="Drew Carlson"
      Version="$(Version)"
      UpgradeCode="0C999EEB-6B48-46C2-8757-E8CE0F5BA2E4"
      Scope="perUser"
      InstallerVersion="500">

    <SummaryInformation Description="Bitwarden CLI client (bwx-cli $(DisplayVersion))" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- LocalAppDataFolder is the per-user equivalent of
         ProgramFiles64Folder; combined with Scope="perUser" this gives
         a UAC-free install. -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="bwx">
          <Directory Id="CompletionFolder" Name="completion" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="bwx-cli" Level="1">
      <Component Id="BwxExe" Directory="INSTALLFOLDER" Guid="*">
        <File Id="BwxExe" Source="$(ExeDir)/bwx.exe" KeyPath="yes" />
        <!-- Append install dir to per-user PATH so `bwx` /
             `bwx-agent` resolve in cmd / PowerShell / Git Bash. -->
        <Environment Id="UpdatePath"
                     Name="PATH"
                     Action="set"
                     Part="last"
                     System="no"
                     Value="[INSTALLFOLDER]" />
      </Component>

      <Component Id="BwxAgentExe" Directory="INSTALLFOLDER" Guid="*">
        <File Id="BwxAgentExe" Source="$(ExeDir)/bwx-agent.exe" KeyPath="yes" />
      </Component>

      <Component Id="ReadmeFile" Directory="INSTALLFOLDER" Guid="*">
        <File Id="ReadmeFile" Source="README.md" KeyPath="yes" />
      </Component>

      <Component Id="LicenseFile" Directory="INSTALLFOLDER" Guid="*">
        <File Id="LicenseFile" Source="LICENSE" KeyPath="yes" />
      </Component>

      <Component Id="CompletionBash" Directory="CompletionFolder" Guid="*">
        <File Id="CompletionBash" Source="$(ExeDir)/completion/bash" Name="bwx.bash" KeyPath="yes" />
      </Component>
      <Component Id="CompletionZsh" Directory="CompletionFolder" Guid="*">
        <File Id="CompletionZsh" Source="$(ExeDir)/completion/zsh" Name="_bwx" KeyPath="yes" />
      </Component>
      <Component Id="CompletionFish" Directory="CompletionFolder" Guid="*">
        <File Id="CompletionFish" Source="$(ExeDir)/completion/fish" Name="bwx.fish" KeyPath="yes" />
      </Component>
    </Feature>
  </Package>
</Wix>
